                            "raw": "{{base_url}}/api/v1/service-providers/reviews",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "service-providers",
                                "reviews"
                            ]
                        },
                        "description": "Get paginated list of VISIBLE reviews for the authenticated service provider."
                    },
                    "response": []
                }
            ]
        },
