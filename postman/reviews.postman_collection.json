{
    "info": {
        "_postman_id": "c2d4e6f8-a0b2-4c6e-8a0c-2e4f6a8b0c2e",
        "name": "GharSeva - Reviews Module",
        "description": "Review endpoints for Users, Providers, and Admins.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "User",
            "item": [
                {
                    "name": "Get My Reviews",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{user_token}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/api/v1/users/reviews",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "users",
                                "reviews"
                            ]
                        },
                        "description": "Get paginated list of reviews submitted by the authenticated customer."
                    },
                    "response": []
                },
                {
                    "name": "Submit Review for Booking",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{user_token}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"rating\": 5,\n    \"review\": \"Excellent service! Very professional and on time.\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/api/v1/users/bookings/:bookingId/review",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "users",
                                "bookings",
                                ":bookingId",
                                "review"
                            ],
                            "variable": [
                                {
                                    "key": "bookingId",
                                    "value": "REPLACE_BOOKING_ID"
                                }
                            ]
                        },
                        "description": "Submit a review for a completed booking. Booking must be COMPLETED and not yet reviewed."
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "Provider",
            "item": [
                {
                    "name": "Get My Reviews",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
