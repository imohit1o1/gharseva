    "item": [
        {
            "name": "Get Current User Profile",
            "request": {
                "auth": {
                    "type": "bearer",
                    "bearer": [
                        {
                            "key": "token",
                            "value": "{{access_token}}",
                            "type": "string"
                        }
                    ]
                },
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "{{base_url}}/api/v1/users/me",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "v1",
                        "users",
                        "me"
                    ]
                },
                "description": "Fetches the profile of the currently authenticated user."
            },
            "response": []
        },
        {
