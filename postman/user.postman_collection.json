                    ]
                },
                "method": "PUT",
                "header": [],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"first_name\": \"John Updated\",\n    \"city\": \"New Delhi\"\n}",
                    "options": {
                        "raw": {
                            "language": "json"
                        }
                    }
